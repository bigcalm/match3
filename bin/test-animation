// в”Ђв”Ђ Scenario 7: hypercube match-activation в”Ђв”Ђ
$g = new Grid(7);
fillNoMatch($g);
$g->setCell(3, 2, 2);
$g->setCell(3, 3, 2);
$g->setCell(3, 4, 2);
$g->setSpecial(3, 3, Grid::HYPERCUBE);
$g->setCell(0, 0, 2);
$g->setCell(7, 7, 2);
$g->setCell(4, 5, 2);
