#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

use Match3\Grid;
use Match3\Input;
use Match3\Renderer;

Input::enableRawMode();
register_shutdown_function([Input::class, 'restoreTerminal']);

$renderer = new Renderer();
$hud = ['level' => 1, 'score' => 0, 'scoreGoal' => 200, 'validMoves' => 0, 'invalidMoves' => 0, 'mode' => 'moves', 'movesLeft' => 40, 'movesTotal' => 40];

function fillNoMatch(Grid $grid): void
{
    for ($r = 0; $r < Grid::ROWS; $r++) {
        for ($c = 0; $c < Grid::COLS; $c++) {
            $grid->setCell($r, $c, ($r + $c) % 7);
        }
    }
}

function waitForAnyKey(): void
{
    fread(STDIN, 64);
}

function describe(string $msg): void
{
    echo "\e[2m{$msg}\e[0m\n";
    if (ob_get_level()) { ob_flush(); } flush();
}

function renderWith(Grid $grid, Renderer $r, array $hud, string $footer, array $highlights = []): void
{
    echo "\e[2J\e[H";
    echo $r->render($grid, 0, 0, -1, -1, $highlights, $hud, $footer);
    if (ob_get_level()) { ob_flush(); } flush();
}

function flash(Grid $grid, Renderer $r, array $cells, array $hud, string $footer): void
{
    for ($i = 0; $i < 3; $i++) {
        echo $r->render($grid, 0, 0, -1, -1, $cells, $hud, $footer);
        if (ob_get_level()) { ob_flush(); } flush(); usleep(250_000);
        echo $r->render($grid, 0, 0, -1, -1, [], $hud, '');
        if (ob_get_level()) { ob_flush(); } flush(); usleep(200_000);
    }
}

function runCascadeStepped(Grid $grid, Renderer $r, array $hud): void
{
    $step = 0;
    do {
        $matches = $grid->findMatches();
        if (empty($matches)) { break; }
        $step++;

        // в”Ђв”Ђ Phase 1: Show match set в”Ђв”Ђ
        describe("Step {$step}: match found (" . count($matches) . " cells). Press any key to flash...");
        waitForAnyKey();
        renderWith($grid, $r, $hud, "MATCH вЂ” highlighted cells will flash", $matches);

        // в”Ђв”Ђ Phase 2: Activate specials в”Ђв”Ђ
        $set = [];
        foreach ($matches as $pos) { $set["{$pos[0]},{$pos[1]}"] = true; }
        $activated = [];
        foreach ($matches as [$mr, $mc]) {
            $sp = $grid->getSpecial($mr, $mc);
            if ($sp !== Grid::NONE) {
                $label = match ($sp) {
                    Grid::BOMB => 'BOMB',
                    Grid::STRIPED_H, Grid::STRIPED_V => 'STRIPED',
                    Grid::HYPERCUBE => 'HYPERCUBE',
                    default => 'SPECIAL',
                };
                $extra = $grid->activateSpecial($mr, $mc);
                describe("{$label} at ({$mr},{$mc}) activates вЂ” " . count($extra) . " cells affected. Press any key to flash...");
                waitForAnyKey();
                foreach ($extra as $ep) {
                    $ek = "{$ep[0]},{$ep[1]}";
                    if (!isset($set[$ek])) { $set[$ek] = true; $activated[] = $ep; }
                }
                // Show the blast area highlighted
                $allWithActivated = array_merge($matches, $activated);
                renderWith($grid, $r, $hud, "BLAST вЂ” activated cells highlighted in addition to match", $allWithActivated);
            }
        }

        // в”Ђв”Ђ Phase 3: Flash animation в”Ђв”Ђ
        $all = array_merge($matches, $activated);
        describe("Flashing " . count($all) . " cells (" . count($matches) . " matched + " . count($activated) . " activated)...");
        flash($grid, $r, $all, $hud, '');

        // в”Ђв”Ђ Phase 4: Create new specials from 4+ matches в”Ђв”Ђ
        $groups = $grid->groupMatches($matches);
        $keep = [];
        foreach ($groups as $g) {
            $size = count($g);
            if ($size >= 4) {
                $pos = $grid->createSpecial($g);
                $keep[] = $pos;
                $type = match ($grid->getSpecial($pos[0], $pos[1])) {
                    Grid::STRIPED_H, Grid::STRIPED_V => 'striped',
                    Grid::BOMB => 'bomb',
                    Grid::HYPERCUBE => 'hypercube',
                    default => 'special',
                };
                describe("{$size}-match spawns a new {$type} gem at ({$pos[0]},{$pos[1]})");
            }
        }

        $keepMap = [];
        foreach ($keep as [$kr, $kc]) { $keepMap["$kr,$kc"] = true; }

        // в”Ђв”Ђ Phase 5: Gap (cells cleared) в”Ђв”Ђ
        $toClear = [];
        foreach ($matches as [$mr, $mc]) {
            if (!isset($keepMap["$mr,$mc"])) { $toClear["$mr,$mc"] = [$mr, $mc]; }
        }
        foreach ($activated as $ap) {
            $ak = "{$ap[0]},{$ap[1]}";
            if (!isset($keepMap[$ak]) && !isset($toClear[$ak])) { $toClear[$ak] = $ap; }
        }

        $grid->removeCells(array_values($toClear));
        if (!empty($toClear)) {
            describe("GAP вЂ” " . count($toClear) . " cells cleared (empty cells shown). Gravity will fill them.");
            echo $r->render($grid, 0, 0, -1, -1, [], $hud, '');
            if (ob_get_level()) { ob_flush(); } flush();
            waitForAnyKey();
        }

        // в”Ђв”Ђ Phase 6: Settle (gravity) в”Ђв”Ђ
        describe("SETTLE вЂ” applying gravity...");
        $grid->applyGravity();
        echo $r->render($grid, 0, 0, -1, -1, [], $hud, '');
        if (ob_get_level()) { ob_flush(); } flush();
        usleep(500_000);

        // Check for next step
        if (!empty($grid->findMatches())) {
            describe("New matches detected after gravity. Press any key for next cascade step...");
            waitForAnyKey();
        }
    } while (true);

    describe("Board stable вЂ” no more matches.");
    renderWith($grid, $r, $hud, "FINAL вЂ” stable board");
    waitForAnyKey();
}

// в”Ђв”Ђ Scenario 1: 3-match в”Ђв”Ђ
$g = new Grid(7);
fillNoMatch($g);
$g->setCell(3, 2, 1);
$g->setCell(3, 3, 1);
$g->setCell(3, 4, 1);
$g->setCell(3, 5, 4);
echo "\e[2J\e[H\e[1mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\e[0m\n";
echo "\e[1mв•‘  1. Basic 3-match                       в•‘\e[0m\n";
echo "\e[1mв• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј\e[0m\n";
echo "\e[1mв•‘  Setup: row 3, cols 2-4 set to в™Ґ (gem 1)в•‘\e[0m\n";
echo "\e[1mв•‘  These 3 cells form a horizontal match. в•‘\e[0m\n";
echo "\e[1mв•‘  No special gem, no cascade.            в•‘\e[0m\n";
echo "\e[1mв•‘  Expected: flash 3Г— в†’ cells disappear  в•‘\e[0m\n";
echo "\e[1mв•‘  в†’ gravity fills в†’ board stable.       в•‘\e[0m\n";
echo "\e[1mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\e[0m\n\n";
renderWith($g, $renderer, $hud, "Initial board. Press any key to begin...");
waitForAnyKey();
runCascadeStepped($g, $renderer, $hud);

// в”Ђв”Ђ Scenario 2: 4-match в†’ creates a striped gem в”Ђв”Ђ
$g = new Grid(7);
fillNoMatch($g);
for ($c = 2; $c <= 5; $c++) { $g->setCell(3, $c, 1); }
$g->setCell(3, 6, 2);
echo "\e[2J\e[H\e[1mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\e[0m\n";
echo "\e[1mв•‘  2. 4-match в†’ creates a striped gem     в•‘\e[0m\n";
echo "\e[1mв• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј\e[0m\n";
echo "\e[1mв•‘  Setup: row 3, cols 2-5 set to в™Ґ       в•‘\e[0m\n";
echo "\e[1mв•‘  4 in a row в†’ special gem created at    в•‘\e[0m\n";
echo "\e[1mв•‘  the first matched cell (3,2).          в•‘\e[0m\n";
echo "\e[1mв•‘  Expected: flash в†’ 3 cells removed      в•‘\e[0m\n";
echo "\e[1mв•‘  (the 4th becomes striped and stays).   в•‘\e[0m\n";
echo "\e[1mв•‘  The striped gem survives gravity and   в•‘\e[0m\n";
echo "\e[1mв•‘  is visible as underlined в™Ґ on the      в•‘\e[0m\n";
echo "\e[1mв•‘  final board.                           в•‘\e[0m\n";
echo "\e[1mв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\e[0m\n\n";
renderWith($g, $renderer, $hud, "Initial board. Press any key to begin...");
waitForAnyKey();
runCascadeStepped($g, $renderer, $hud);

// в”Ђв”Ђ Scenario 3: 5-match в†’ creates a bomb в”Ђв”Ђ
