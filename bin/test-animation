// в”Ђв”Ђ Scenario 8: multi-cascade в”Ђв”Ђ
$g = new Grid(7);
fillNoMatch($g);
$g->setCell(7, 2, 0);
$g->setCell(7, 3, 0);
$g->setCell(7, 4, 0);
$g->setCell(6, 2, 1);
$g->setCell(5, 2, 1);
$g->setCell(3, 2, 1);
echo "\e[2J\e[H\e[1mв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—\e[0m\n";
echo "\e[1mв•‘  8. Multi-cascade                        в•‘\e[0m\n";
echo "\e[1mв• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј\e[0m\n";
echo "\e[1mв•‘  Step 1: three в™¦ at row 7, cols 2-4    в•‘\e[0m\n";
