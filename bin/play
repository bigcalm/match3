#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

use Match3\Game;
use Match3\HighScoreBoard;
use Match3\Input;

register_shutdown_function([Input::class, 'restoreTerminal']);

$board = new HighScoreBoard();

do {
    Input::enableRawMode();
    Input::enableMouseTracking();

    $game = new Game();
    $result = $game->run();

    Input::restoreTerminal();

    if (empty($result)) {
        break;
    }

    echo "\e[2J\e[H";

    if ($result['won']) {
        echo "You win! Final score: {$result['score']}\n";
    } else {
        echo "Game over! Score: {$result['score']}  (Reached level {$result['level']})\n";
    }

    if ($board->isHighScore($result['score'])) {
        echo "New high score: {$result['score']}!\n";
        echo "Enter your name: ";
        $name = trim(fgets(STDIN));

        if ($name === '') {
            $name = 'Anonymous';
        }

        $board->add($name, $result['score'], $result['level'], $result['validMoves'], $result['invalidMoves']);
    }

    echo "\n" . $board->render();

    echo "Play again? (y/n): ";
    $answer = strtolower(trim(fgets(STDIN)));
} while ($answer === 'y');
