#!/usr/bin/env php
<?php

require __DIR__ . '/../vendor/autoload.php';

use Match3\Game;
use Match3\HighScoreBoard;
use Match3\Input;
use Match3\KeyBindings;
use Match3\WelcomeScreen;

register_shutdown_function([Input::class, 'restoreTerminal']);

Input::enableRawMode();

$input = new Input(new KeyBindings('arrows'));
$welcome = new WelcomeScreen($input);

while (true) {
    $welcomeResult = $welcome->run();

    if ($welcomeResult['action'] === 'quit') {
        break;
    }

    if ($welcomeResult['action'] === 'leaderboard') {
        Input::restoreTerminal();

        $board = new HighScoreBoard();
        echo "\e[2J\e[H" . $board->renderAll();
        echo "\nPress Enter to return...";
        fgets(STDIN);

        Input::enableRawMode();
        continue;
    }

    $mode = $welcomeResult['mode'];
    $preset = $welcomeResult['preset'];

    Game::play($preset, null, $mode);

    Input::enableRawMode();
}

Input::restoreTerminal();
